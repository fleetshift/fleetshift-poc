# GCP HCP addon configuration
#
# Copy this file to gcphcp.yaml and fill in your environment-specific values.
# Pass it to the server via --gcphcp-config=gcphcp.yaml or mount it into the
# container via the GCPHCP_CONFIG env var used by deploy/podman/overrides/gcphcp.yaml.
#
# All fields are required.

gateway:
  # HCP backend gateway URL and OAuth audience
  url: https://cls-backend-gateway-XXXXXXXX.uc.gateway.dev
  audience: XXXXXXXXXXXX.apps.googleusercontent.com

targets:
  - id: my-target
    gcp_project: my-gcp-project-id
    region: us-central1
    workforce_pool: my-workforce-pool
    workforce_provider: my-workforce-provider
    broker_sa_email: broker@my-gcp-project-id.iam.gserviceaccount.com
